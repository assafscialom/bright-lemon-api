APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8081,http://127.0.0.1:8081,http://localhost:5173,http://127.0.0.1:5173
BRIGHT_LEMON_DEMO_OTP=123456
BRIGHT_LEMON_DEFAULT_BRANCH="Branch drop-off pending"
BRIGHT_LEMON_EMS_ENABLED=false
BRIGHT_LEMON_EMS_CURRENCY=USD
BRIGHT_LEMON_EMS_RATE_API_URL=
BRIGHT_LEMON_EMS_RATE_CARRIER=israel_post
BRIGHT_LEMON_EMS_TIMEOUT=30
BRIGHT_LEMON_EMS_DEFAULT_RECIPIENT_POSTAL_CODE=00000
BRIGHT_LEMON_EMS_DEFAULT_PARCEL_LENGTH_CM=10
BRIGHT_LEMON_EMS_DEFAULT_PARCEL_WIDTH_CM=10
BRIGHT_LEMON_EMS_DEFAULT_PARCEL_HEIGHT_CM=10
BRIGHT_LEMON_EMS_ALLOWED_WARNING_CODES=201
BRIGHT_LEMON_EMS_SENDER_COUNTRY_CODE=IL
ISRAEL_POST_SDK_MODE=test
ISRAEL_POST_SDK_API_URL=
ISRAEL_POST_SDK_AUTH_INTERNATIONAL_SUBSCRIPTION_KEY_METHODS=
ISRAEL_POST_SDK_AUTH_SEND_PARCEL_INFO_API_OCP_APIM_SUBSCRIPTION_KEY=
ISRAEL_POST_SDK_AUTH_OCP_APIM_SUBSCRIPTION_KEY=
ISRAEL_POST_SDK_AUTH_USERNAME=
ISRAEL_POST_SDK_AUTH_PASSWORD=
ISRAEL_POST_SDK_SETTINGS_INTL_PARTNER_CODE=400327

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
